# xllmapi Environment Configuration
# Copy to .env and fill in values

# --- Required (Production) ---
XLLMAPI_ENV=development          # "development" | "production"
XLLMAPI_SECRET_KEY=              # AES-256-GCM key for encrypting provider API keys (required in production)
XLLMAPI_DB_DRIVER=postgres       # "sqlite" | "postgres"
DATABASE_URL=postgresql://xllmapi:xllmapi@127.0.0.1:5432/xllmapi
REDIS_URL=redis://127.0.0.1:6379

# --- Optional ---
PORT=3000                        # HTTP listen port
HOST=0.0.0.0                     # HTTP listen host
XLLMAPI_CORS_ORIGINS=            # Comma-separated allowed origins (production only, e.g. "https://app.example.com,https://admin.example.com")
XLLMAPI_RELEASE_ID=dev           # Release identifier used for versioned static assets and /version
XLLMAPI_APP_BASE_URL=http://127.0.0.1:3000
XLLMAPI_NODE_IMAGE=swr.cn-north-4.myhuaweicloud.com/ddn-k8s/docker.io/node:24-bookworm-slim
XLLMAPI_REQUEST_BODY_MAX_BYTES=1048576
XLLMAPI_AUTH_REQUEST_CODE_LIMIT_PER_MINUTE=5
XLLMAPI_AUTH_VERIFY_CODE_LIMIT_PER_MINUTE=10
XLLMAPI_AUTH_PASSWORD_LOGIN_LIMIT_PER_MINUTE=10
XLLMAPI_AUTH_CODE_TTL_SECONDS=600
XLLMAPI_PASSWORD_RESET_TTL_SECONDS=1800
XLLMAPI_EMAIL_CHANGE_TTL_SECONDS=1800
XLLMAPI_EMAIL_SEND_COOLDOWN_SECONDS=60
XLLMAPI_ASSET_RETENTION_COUNT=3  # How many frontend release asset folders to keep on disk
XLLMAPI_SESSION_COOKIE_NAME=xllmapi_session
XLLMAPI_SESSION_MAX_AGE_SECONDS=2592000
XLLMAPI_EMAIL_PROVIDER=mock      # "mock" for dev/test, "resend" for production
XLLMAPI_EMAIL_FROM=
XLLMAPI_EMAIL_REPLY_TO=
XLLMAPI_RESEND_API_KEY=
XLLMAPI_SECURITY_NOTIFY_EMAIL_ENABLED=1
XLLMAPI_SETTLEMENT_RETRY_LIMIT=100
XLLMAPI_SETTLEMENT_RETRY_DRY_RUN=0
XLLMAPI_SETTLEMENT_RETRY_FAIL_ON_OPEN_REMAINING=0

# --- Provider API Keys (for platform-owned offerings) ---
XLLMAPI_DEEPSEEK_API_KEY=        # DeepSeek API key

# --- Tuning ---
XLLMAPI_CHAT_RATE_LIMIT_PER_MINUTE=60  # Per-API-key rate limit for chat endpoints

# --- Development Only ---
XLLMAPI_DB_PATH=                 # SQLite file path (when XLLMAPI_DB_DRIVER=sqlite)
XLLMAPI_DEV_LOG_DIR=/tmp/xllmapi-dev  # Log directory for dev scripts
