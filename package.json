{
  "name": "xllmapi",
  "private": true,
  "version": "0.1.0",
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "build": "npm run build --workspace @xllmapi/logger && npm run build --workspace @xllmapi/shared-types && npm run build --workspace @xllmapi/core && npm run build --workspace @xllmapi/web && npm run build --workspace @xllmapi/platform-api",
    "build:web": "npm run build --workspace @xllmapi/web",
    "dev:web": "npm run dev --workspace @xllmapi/web",
    "dev:platform-api": "npm run dev --workspace @xllmapi/platform-api",
    "build:platform-api": "npm run build --workspace @xllmapi/platform-api",
    "build:shared-types": "npm run build --workspace @xllmapi/shared-types",
    "ops:retry:settlement-failures": "npm run ops:retry:settlement-failures --workspace @xllmapi/platform-api",
    "smoke:release": "bash scripts/release-smoke.sh",
    "test:platform-api": "npm run test --workspace @xllmapi/platform-api",
    "test:e2e:sharing": "node scripts/e2e-sharing-flow.mjs",
    "test:e2e:mvp": "node scripts/e2e-mvp-flow.mjs",
    "dev:up": "bash scripts/dev-up.sh",
    "dev:down": "bash scripts/dev-down.sh"
  }
}
